# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/lotos?schema=public

# Redis (Upstash)
REDIS_URL=redis://default:token@host:6379

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=lotos_bot

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Eskiz SMS (Uzbekistan)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# Payme
PAYME_MERCHANT_ID=
PAYME_KEY=

# Click
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# App URLs
LANDING_URL=https://lotos-studio.uz
MINIAPP_URL=https://app.lotos-studio.uz
API_URL=https://api.lotos-studio.uz
ADMIN_URL=https://admin.lotos-studio.uz

# Environment
NODE_ENV=development
